{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "auction.basket.opened",
  "title": "auction.basket.opened",
  "description": "A specific basket is opened for bidding. Produced by the Auction & Bidding Service (3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "basketId", "basePrice", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "basketId": { "type": "string", "minLength": 1 },
    "basePrice": { "type": "number", "exclusiveMinimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
