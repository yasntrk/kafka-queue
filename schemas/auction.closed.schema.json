{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "auction.closed",
  "title": "auction.closed",
  "description": "The auction session is closed after all sales and payments are settled. Produced by the Post-Auction & Fulfillment Service (4).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "closedAt", "totalRevenue", "soldBasketCount", "unsoldBasketCount", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "closedAt": { "type": "string", "format": "date-time" },
    "totalRevenue": { "type": "number", "minimum": 0 },
    "soldBasketCount": { "type": "integer", "minimum": 0 },
    "unsoldBasketCount": { "type": "integer", "minimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
