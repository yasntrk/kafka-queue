{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bid.all.baskets.finalized",
  "title": "bid.all.baskets.finalized",
  "description": "Every basket in the session has reached a terminal state (sold or unsold). Marks the end of the bidding phase. Produced by the Auction & Bidding Service (3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "totalBaskets", "soldBasketCount", "unsoldBasketCount", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "totalBaskets": { "type": "integer", "minimum": 0 },
    "soldBasketCount": { "type": "integer", "minimum": 0 },
    "unsoldBasketCount": { "type": "integer", "minimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
