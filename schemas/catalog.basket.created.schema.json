{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "catalog.basket.created",
  "title": "catalog.basket.created",
  "description": "A basket/lot has been created and classified (species, quantity, quality) with a base price. Produced by the Pre-Auction Catalog Service (2).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "basketId", "species", "quantity", "unit", "basePrice", "boatName", "occurredAt"],
  "properties": {
    "eventName": { "type": "string", "description": "Optional self-describing event type; equals the topic name. Not required." },
    "eventId": { "type": "string", "format": "uuid" },
    "basketId": { "type": "string", "minLength": 1 },
    "species": { "type": "string", "minLength": 1 },
    "quantity": { "type": "number", "exclusiveMinimum": 0 },
    "unit": { "type": "string", "enum": ["kg", "piece"] },
    "quality": { "type": "string" },
    "basePrice": { "type": "number", "exclusiveMinimum": 0 },
    "boatName": { "type": "string", "minLength": 1 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
