{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user.buyer.registered",
  "title": "user.buyer.registered",
  "description": "A buyer (customer) has registered to join the auction. Produced by the User & Membership Service (1).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "buyerId", "name", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "buyerId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "email": { "type": "string", "format": "email" },
    "phone": { "type": "string" },
    "address": { "type": "string" },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
