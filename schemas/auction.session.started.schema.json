{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "auction.session.started",
  "title": "auction.session.started",
  "description": "The live auction session has started (the 'bell rings'). Produced by the Auction & Bidding Service (3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "startTime", "totalBaskets", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "startTime": { "type": "string", "format": "date-time" },
    "totalBaskets": { "type": "integer", "minimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
