{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bid.basket.sold",
  "title": "bid.basket.sold",
  "description": "A basket received at least one valid bid and was sold to the highest bidder. Produced by the Auction & Bidding Service (3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "basketId", "buyerId", "winningBidId", "salePrice", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "basketId": { "type": "string", "minLength": 1 },
    "buyerId": { "type": "string", "minLength": 1 },
    "winningBidId": { "type": "string", "minLength": 1 },
    "salePrice": { "type": "number", "exclusiveMinimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
