{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bid.placed",
  "title": "bid.placed",
  "description": "A buyer placed a bid on an open basket. Produced by the Auction & Bidding Service (3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "basketId", "buyerId", "bidId", "bidAmount", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "basketId": { "type": "string", "minLength": 1 },
    "buyerId": { "type": "string", "minLength": 1 },
    "bidId": { "type": "string", "minLength": 1 },
    "bidAmount": { "type": "number", "exclusiveMinimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
