{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bid.payment.confirmed",
  "title": "bid.payment.confirmed",
  "description": "Payment for a sold basket has been confirmed. Produced by the Post-Auction & Fulfillment Service (4).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "basketId", "buyerId", "amount", "paymentStatus", "occurredAt"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "basketId": { "type": "string", "minLength": 1 },
    "buyerId": { "type": "string", "minLength": 1 },
    "amount": { "type": "number", "exclusiveMinimum": 0 },
    "paymentStatus": { "type": "string", "const": "CONFIRMED" },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
