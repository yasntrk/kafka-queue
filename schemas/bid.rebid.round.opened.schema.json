{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bid.rebid.round.opened",
  "title": "bid.rebid.round.opened",
  "description": "A re-auction round is opened for one or more previously unsold baskets. Produced by the Auction & Bidding Service (3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "roundNumber", "basketIds", "occurredAt"],
  "properties": {
    "eventName": { "type": "string", "description": "Optional self-describing event type; equals the topic name. Not required." },
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "roundNumber": { "type": "integer", "minimum": 1 },
    "basketIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
