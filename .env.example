# ---------------------------------------------------------------------------
# Fish Auction Queue - environment configuration
# Copy this file to ".env" and adjust for your environment.
# ---------------------------------------------------------------------------

# Hostname/IP that EXTERNAL Kafka clients (other microservices, your laptop,
# other teams) use to reach the broker. This becomes Kafka's advertised
# listener, so it MUST be reachable from wherever clients connect.
#   - Local Docker:  localhost
#   - AWS EC2:       your instance's public IP or public DNS
#                    (e.g. 16.171.x.x  or  ec2-16-171-x-x.eu-north-1.compute.amazonaws.com)
KAFKA_ADVERTISED_HOST=localhost

# Bootstrap servers used by the Node.js clients in THIS repo
# (producer / consumer / admin scripts).
#   - On the same machine as Docker:  localhost:29092
#   - From another machine:           <KAFKA_ADVERTISED_HOST>:29092
KAFKA_BROKERS=localhost:29092

# Client id reported to the broker (shows up in Kafka UI / logs).
KAFKA_CLIENT_ID=fish-auction-queue

# ---------------------------------------------------------------------------
# OPTION B - Shared managed cluster (Confluent Cloud) for all teams.
# Use this instead of the local broker when other teams need to connect over
# the internet. Get these values from the Confluent Cloud console.
# When SASL is set, TLS is enabled automatically.
# ---------------------------------------------------------------------------
# KAFKA_BROKERS=pkc-xxxxx.<region>.aws.confluent.cloud:9092
# KAFKA_SASL_MECHANISM=plain
# KAFKA_SASL_USERNAME=<CLUSTER_API_KEY>
# KAFKA_SASL_PASSWORD=<CLUSTER_API_SECRET>
# KAFKA_REPLICATION_FACTOR=3        # Confluent Cloud requires RF=3 (used by topics:create)
