    { "topic": "bid.basket.sold",                         "partitions": 3, "replicationFactor": 1 },
    { "topic": "bid.basket.unsold",                       "partitions": 3, "replicationFactor": 1 },
    { "topic": "bid.rebid.round.opened",                  "partitions": 1, "replicationFactor": 1 },
